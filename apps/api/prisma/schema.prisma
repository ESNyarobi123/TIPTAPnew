// TIPTAP — multi-tenant service-commerce domain model
// All tenant-owned rows include tenantId; branch-scoped entities include branchId where applicable.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ——— Platform enums ———

enum RoleCode {
  SUPER_ADMIN
  TENANT_OWNER
  BRANCH_MANAGER
  CASHIER
  SERVICE_STAFF
  SUPPORT_AGENT
}

enum BusinessCategory {
  FOOD_DINING
  BEAUTY_GROOMING
}

enum TenantStatus {
  ACTIVE
  TRIAL
  SUSPENDED
  ARCHIVED
}

enum QrType {
  BUSINESS_QR
  STAFF_QR
  TABLE_QR
  STATION_QR
}

enum QrStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum StaffAssignmentStatus {
  ACTIVE
  ENDED
}

enum StaffAssignmentMode {
  /// Default: staff can be assigned to multiple branches as needed.
  PART_TIME_SHARED
  /// Staff is exclusive to a single active assignment at a time (within a tenant).
  FULL_TIME_EXCLUSIVE
  /// Short-lived work agreement (still can be shared unless policy says otherwise).
  TEMPORARY_CONTRACT
  /// Flexible schedule; multiple assignments are expected.
  SHIFT_BASED
}

enum ConversationChannel {
  WHATSAPP
  WEB
  API
  OTHER
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum StaffEmploymentStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
}

enum StaffCompensationType {
  SALARY
  BONUS
  COMMISSION
  ADVANCE
  DEDUCTION
}

enum StaffCompensationStatus {
  SCHEDULED
  APPROVED
  PAID
  VOID
}

/// Aligned with bill + assistance operational flow: PENDING → ACKNOWLEDGED → RESOLVED (or CANCELLED).
enum WaiterCallStatus {
  PENDING
  ACKNOWLEDGED
  RESOLVED
  CANCELLED
}

/// Physical / logical table state for floor ops (distinct from soft-delete isActive).
enum DiningTableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  OUT_OF_SERVICE
}

enum BeautyStationStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  OUT_OF_SERVICE
}

enum BillRequestStatus {
  PENDING
  ACKNOWLEDGED
  RESOLVED
  CANCELLED
}

enum DiningSupportStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum AssistanceRequestStatus {
  PENDING
  ACKNOWLEDGED
  RESOLVED
  CANCELLED
}

/// FOOD_DINING cart / kitchen lifecycle.
enum DiningOrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  SERVED
  COMPLETED
  CANCELLED
}

enum DiningOrderItemStatus {
  PENDING
  PREPARING
  READY
  SERVED
  CANCELLED
}

/// BEAUTY_GROOMING appointment lifecycle.
enum BeautyBookingStatus {
  BOOKED
  CONFIRMED
  CHECKED_IN
  IN_SERVICE
  COMPLETED
  PAID
  CANCELLED
  NO_SHOW
}

enum BeautyBookingServiceStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum RatingTargetType {
  BUSINESS
  STAFF
  SERVICE
  PROVIDER_EXPERIENCE
}

enum TipStatus {
  RECORDED
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum TipMode {
  CASH
  DIGITAL
}

enum PaymentProviderKey {
  MOCK
  STRIPE
  PAYSTACK
  CLICKPESA
  OTHER
}

enum PaymentTransactionType {
  COLLECTION
  PAYOUT
  TIP_DIGITAL
}

enum PaymentTransactionStatus {
  PENDING
  REQUIRES_ACTION
  COMPLETED
  FAILED
  REFUNDED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  ACCESS
  CONFIG_CHANGE
}

// ——— Core platform ———

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  passwordHash      String
  firstName         String?
  lastName          String?
  phone             String?
  isActive          Boolean   @default(true)
  lastLoginAt       DateTime?
  passwordChangedAt DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  roleAssignments UserRoleAssignment[]
  refreshTokens   RefreshToken[]
  staffProfiles   Staff[]              @relation("UserStaff")
  providerProfile ProviderProfile?     @relation("ProviderProfileOwner")
  auditLogs       AuditLog[]           @relation("AuditActor")
}

/// Scoped role grants: SUPER_ADMIN may omit tenantId/branchId; branch roles set branchId.
model UserRoleAssignment {
  id        String   @id @default(cuid())
  userId    String
  role      RoleCode
  tenantId  String?
  branchId  String?
  createdAt DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch? @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenantId])
  @@index([branchId])
}

model RefreshToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String
  expiresAt  DateTime
  revokedAt  DateTime?
  lastUsedAt DateTime?
  userAgent  String?
  ipAddress  String?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
}

model Tenant {
  id                   String       @id @default(cuid())
  name                 String
  slug                 String       @unique
  status               TenantStatus @default(TRIAL)
  legalName            String?
  email                String?
  phone                String?
  subscriptionPlan     String?
  subscriptionStatus   String?
  metadata             Json?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  deletedAt            DateTime?

  branches         Branch[]
  categories       TenantCategory[]
  landingPage      TenantLandingPage?
  staff            Staff[]
  userRoles        UserRoleAssignment[]
  qrCodes          QrCode[]
  sessions         ConversationSession[]
  ratings          Rating[]
  tips             Tip[]
  paymentConfigs   PaymentProviderConfig[]
  paymentTxns      PaymentTransaction[]
  auditLogs        AuditLog[]
  menuCategories   DiningMenuCategory[]
  menuItems        DiningMenuItem[]
  diningTables     DiningTable[]
  waiterCalls      WaiterCallRequest[]
  billRequests     BillRequest[]
  diningSupports   DiningCustomerServiceRequest[]
  beautyCategories BeautyServiceCategory[]
  beautyServices   BeautyService[]
  beautyStations   BeautyStation[]
  assistanceReqs   AssistanceRequest[]
  staffCompensations StaffCompensation[]
  diningOrders     DiningOrder[]
  beautyBookings   BeautyBooking[]
  kdsTokens        KdsToken[]
  qdsTokens        QdsToken[]
  staffJoinInvites StaffJoinInvite[]
}

model TenantLandingPage {
  id          String   @id @default(cuid())
  tenantId    String   @unique
  /// Public URL path: /t/{slug}. Defaults to Tenant.slug at first save.
  slug        String   @unique
  title       String?
  subtitle    String?
  heroCtaText String?
  heroCtaHref String?
  theme       Json?
  sections    Json?
  isPublished Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([slug])
  @@index([isPublished])
}

model Branch {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  code      String
  address   String?
  city      String?
  country   String?
  phone     String?
  email     String?
  latitude  Decimal? @db.Decimal(10, 7)
  longitude Decimal? @db.Decimal(10, 7)
  timezone  String?  @default("UTC")
  /// Weekly opening hours: `{ "mon": [{ "open": "09:00", "close": "17:00" }], ... }` (keys mon..sun, branch-local times).
  operatingHours Json?
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userRoles        UserRoleAssignment[]
  staffAssignments StaffAssignment[]
  staff            Staff[]
  qrCodes          QrCode[]
  sessions         ConversationSession[]
  ratings          Rating[]
  tips             Tip[]
  auditLogs        AuditLog[]
  menuCategories   DiningMenuCategory[]
  menuItems        DiningMenuItem[]
  diningTables     DiningTable[]
  waiterCalls      WaiterCallRequest[]
  billRequests     BillRequest[]
  diningSupports   DiningCustomerServiceRequest[]
  beautyCategories BeautyServiceCategory[]
  beautyServices   BeautyService[]
  beautyStations   BeautyStation[]
  assistanceReqs   AssistanceRequest[]
  paymentTxns      PaymentTransaction[]
  staffCompensations StaffCompensation[]
  diningOrders     DiningOrder[]
  beautyBookings   BeautyBooking[]
  kdsTokens        KdsToken[]
  qdsTokens        QdsToken[]
  /// Monotonic per-branch sequence for human-readable order numbers (ORD-{code}-NNNN).
  nextDiningOrderSeq    Int @default(0)
  /// Monotonic per-branch sequence for booking numbers (BKG-{code}-NNNN).
  nextBeautyBookingSeq  Int @default(0)
  staffJoinInvites      StaffJoinInvite[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

/// One-time or limited-use codes so providers self-link to a branch (manager-generated).
model StaffJoinInvite {
  id              String              @id @default(cuid())
  codeNormalized  String              @unique
  tenantId        String
  branchId        String
  roleInTenant    RoleCode            @default(SERVICE_STAFF)
  mode            StaffAssignmentMode @default(PART_TIME_SHARED)
  maxUses         Int                 @default(1)
  usesCount       Int                 @default(0)
  expiresAt       DateTime?
  revokedAt       DateTime?
  createdByUserId String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([branchId])
}

model TenantCategory {
  id         String           @id @default(cuid())
  tenantId   String
  category   BusinessCategory
  enabled    Boolean          @default(true)
  settings   Json?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, category])
  @@index([tenantId])
}

/// Global portable provider identity (public-facing summary). Private HR/payroll stays off this model.
model ProviderProfile {
  id                 String   @id @default(cuid())
  userId             String?  @unique
  publicSlug         String?  @unique
  registryCode       String?  @unique
  displayName        String
  headline           String?
  bio                String?
  verifiedSummary    String?
  publicRatingAvg    Decimal? @db.Decimal(4, 2)
  publicRatingCount  Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  deletedAt          DateTime?

  /// Encrypted or restricted — never expose in public DTOs (use dedicated internal service).
  internalNotes      String?  @db.Text
  /// Public skill tags (JSON array of strings); safe for /public endpoint.
  skills             Json?

  user  User?   @relation("ProviderProfileOwner", fields: [userId], references: [id], onDelete: SetNull)
  staff Staff[]
}

model Staff {
  id                 String                @id @default(cuid())
  tenantId           String
  branchId           String?
  userId             String?
  providerProfileId  String?
  displayName        String
  email              String?
  phone              String?
  roleInTenant       RoleCode              @default(SERVICE_STAFF)
  status             StaffEmploymentStatus @default(ACTIVE)
  hireDate           DateTime?
  /// Portable reference for QR / public lookup (non-secret handle).
  publicHandle       String?
  /// Sensitive — internal APIs only.
  privateNotes       String?               @db.Text
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  deletedAt          DateTime?

  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch          Branch?           @relation(fields: [branchId], references: [id], onDelete: SetNull)
  user            User?             @relation("UserStaff", fields: [userId], references: [id], onDelete: SetNull)
  providerProfile ProviderProfile?  @relation(fields: [providerProfileId], references: [id], onDelete: SetNull)
  assignments          StaffAssignment[]
  qrCodes              QrCode[]
  specializations      ProviderSpecialization[]
  ratings              Rating[]
  tips                 Tip[]
  compensations        StaffCompensation[]
  conversationSessions ConversationSession[]
  waiterCallTargets    WaiterCallRequest[]
  assistanceRequests   AssistanceRequest[]
  diningOrdersWaiter       DiningOrder[]            @relation("DiningOrderWaiter")
  diningOrdersClaimed      DiningOrder[]            @relation("DiningOrderClaimedBy")
  beautyBookingsAsProvider BeautyBooking[]          @relation("BeautyBookingProvider")
  beautyBookingServices    BeautyBookingService[]   @relation("BeautyBookingServiceStaff")
  createdKdsTokens         KdsToken[]               @relation("KdsTokenCreatedBy")
  createdQdsTokens         QdsToken[]               @relation("QdsTokenCreatedBy")

  @@index([tenantId])
  @@index([branchId])
  @@index([providerProfileId])
  @@index([publicHandle])
}

model StaffAssignment {
  id        String                 @id @default(cuid())
  staffId   String
  branchId  String
  status    StaffAssignmentStatus  @default(ACTIVE)
  mode      StaffAssignmentMode    @default(PART_TIME_SHARED)
  startedAt DateTime               @default(now())
  endedAt   DateTime?

  staff  Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([staffId])
  @@index([branchId])
  @@index([staffId, status])
}

model StaffCompensation {
  id            String                  @id @default(cuid())
  tenantId      String
  branchId      String?
  staffId       String
  type          StaffCompensationType   @default(SALARY)
  status        StaffCompensationStatus @default(SCHEDULED)
  amountCents   Int
  currency      String                  @default("TZS")
  periodLabel   String?
  periodStart   DateTime?
  periodEnd     DateTime?
  effectiveDate DateTime                @default(now())
  paidAt        DateTime?
  notes         String?                 @db.Text
  createdByUserId String?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  staff  Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([branchId])
  @@index([staffId])
  @@index([staffId, status])
  @@index([effectiveDate])
}

model QrCode {
  id               String    @id @default(cuid())
  tenantId         String
  branchId         String?
  type             QrType
  status           QrStatus  @default(ACTIVE)
  /// SHA-256 of secret token (never store raw token)
  tokenHash        String    @unique
  /// Short public ref for URLs (not sufficient alone to resolve; must verify signature/hash server-side)
  publicRef        String
  staffId          String?
  diningTableId    String?
  beautyStationId  String?
  metadata         Json?
  expiresAt        DateTime?
  revokedAt        DateTime?
  scanCount        Int       @default(0)
  lastScannedAt    DateTime?
  rotatedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch        Branch?       @relation(fields: [branchId], references: [id], onDelete: SetNull)
  staff         Staff?        @relation(fields: [staffId], references: [id], onDelete: SetNull)
  diningTable   DiningTable?  @relation(fields: [diningTableId], references: [id], onDelete: SetNull)
  beautyStation BeautyStation? @relation(fields: [beautyStationId], references: [id], onDelete: SetNull)
  sessions      ConversationSession[]

  @@unique([tenantId, publicRef])
  @@index([tenantId, type])
  @@index([tenantId, status])
  @@index([branchId])
}

model ConversationSession {
  id                 String              @id @default(cuid())
  tenantId           String
  branchId           String?
  channel            ConversationChannel
  externalCustomerId String?
  qrCodeId           String?
  staffId            String?
  diningTableId      String?
  beautyStationId    String?
  /// High-level state key for engine (e.g. MAIN_MENU, FOOD_ORDER_FLOW)
  currentState       String              @default("ENTRY")
  /// Serialized menu position / stack for back navigation
  menuState          Json?
  language           String              @default("en")
  /// Snapshot from last QR resolution (type, ids); no secrets.
  qrContext          Json?
  /// SHA-256 of opaque client session token (WhatsApp/web handoff).
  clientTokenHash    String?             @unique
  lastInboundAt      DateTime?
  lastActivityAt     DateTime?
  expiresAt          DateTime?
  metadata           Json?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deletedAt          DateTime?

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch        Branch?       @relation(fields: [branchId], references: [id], onDelete: SetNull)
  qrCode        QrCode?       @relation(fields: [qrCodeId], references: [id], onDelete: SetNull)
  staff         Staff?        @relation(fields: [staffId], references: [id], onDelete: SetNull)
  diningTable   DiningTable?  @relation(fields: [diningTableId], references: [id], onDelete: SetNull)
  beautyStation BeautyStation? @relation(fields: [beautyStationId], references: [id], onDelete: SetNull)
  messages      ConversationMessage[]
  ratings       Rating[]
  tips          Tip[]
  waiterCalls   WaiterCallRequest[]
  billRequests  BillRequest[]
  diningSupports DiningCustomerServiceRequest[]
  assistance    AssistanceRequest[]
  paymentTxns   PaymentTransaction[]
  diningOrders  DiningOrder[]
  beautyBookings BeautyBooking[]

  @@index([tenantId, externalCustomerId])
  @@index([qrCodeId])
  @@index([tenantId, expiresAt])
}

model ConversationMessage {
  id        String           @id @default(cuid())
  sessionId String
  direction MessageDirection
  body      String           @db.Text
  payload   Json?
  createdAt DateTime         @default(now())

  session ConversationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model Rating {
  id         String             @id @default(cuid())
  tenantId   String
  branchId   String?
  /// Active vertical when rated (FOOD_DINING / BEAUTY_GROOMING).
  vertical   BusinessCategory?
  targetType RatingTargetType
  targetId   String
  staffId    String?
  sessionId  String?
  score      Int
  maxScore   Int                @default(5)
  comment    String?            @db.Text
  metadata   Json?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  deletedAt  DateTime?

  tenant  Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch  Branch?              @relation(fields: [branchId], references: [id], onDelete: SetNull)
  staff   Staff?               @relation(fields: [staffId], references: [id], onDelete: SetNull)
  session ConversationSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([tenantId, targetType, targetId])
  @@index([tenantId, createdAt])
  @@index([staffId])
  @@index([sessionId, targetType, targetId])
}

model Tip {
  id              String    @id @default(cuid())
  tenantId        String
  branchId        String?
  staffId         String
  sessionId       String?
  mode            TipMode   @default(DIGITAL)
  amountCents     Int
  currency        String    @default("USD")
  status          TipStatus @default(PENDING)
  paymentTxnId      String?
  /// Open dining order this tip was tied to (e.g. same WhatsApp session).
  diningOrderId     String?
  /// Open beauty booking this tip was tied to (e.g. same WhatsApp session).
  beautyBookingId   String?
  metadata        Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant        Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch        Branch?              @relation(fields: [branchId], references: [id], onDelete: SetNull)
  staff         Staff                @relation(fields: [staffId], references: [id], onDelete: Cascade)
  session       ConversationSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  paymentTxn    PaymentTransaction?  @relation(fields: [paymentTxnId], references: [id], onDelete: SetNull)
  diningOrder   DiningOrder?         @relation(fields: [diningOrderId], references: [id], onDelete: SetNull)
  beautyBooking BeautyBooking?       @relation(fields: [beautyBookingId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([staffId])
  @@index([diningOrderId])
  @@index([beautyBookingId])
}

model PaymentProviderConfig {
  id                   String             @id @default(cuid())
  tenantId             String
  provider             PaymentProviderKey @default(MOCK)
  displayName          String
  /// AES-GCM ciphertext (see PaymentCredentialsCrypto); JSON payload for ClickPesa: clientId, apiKey, checksumKey?, webhookSecret?.
  credentialsEncrypted String             @db.Text
  settings             Json?
  isActive             Boolean            @default(true)
  collectionEnabled    Boolean            @default(false)
  payoutEnabled        Boolean            @default(false)
  /// Last successful inbound webhook that updated a transaction (dashboard / reconciliation visibility).
  lastWebhookAt        DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  tenant       Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transactions PaymentTransaction[]

  @@unique([tenantId, provider])
  @@index([tenantId])
}

model PaymentTransaction {
  id                 String                   @id @default(cuid())
  tenantId           String
  branchId           String?
  sessionId          String?
  providerConfigId   String?
  type               PaymentTransactionType   @default(COLLECTION)
  amountCents        Int
  currency           String
  status             PaymentTransactionStatus @default(PENDING)
  /// Merchant-unique reference sent to ClickPesa; also used for idempotent reconciliation.
  orderReference     String                   @unique
  /// Provider transaction id from status query / webhook (distinct from orderReference).
  externalRef        String?
  phoneNumber        String?
  rawRequest         Json?
  rawResponse        Json?
  lastProviderStatus String?
  metadata           Json?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  tenant         Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch         Branch?                @relation(fields: [branchId], references: [id], onDelete: SetNull)
  session        ConversationSession?   @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  providerConfig PaymentProviderConfig? @relation(fields: [providerConfigId], references: [id], onDelete: SetNull)
  tips                       Tip[]
  diningOrderCollection     DiningOrder?   @relation("CollectionPaymentDiningOrder")
  beautyBookingCollection    BeautyBooking? @relation("CollectionPaymentBeautyBooking")

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, type, createdAt])
  @@index([status])
}

model AuditLog {
  id             String      @id @default(cuid())
  tenantId       String?
  actorUserId    String?
  actorType      String      @default("USER")
  action         AuditAction
  entityType     String
  entityId       String?
  branchId       String?
  correlationId  String?
  summary        String?
  details        Json?
  changes        Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime    @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  branch Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  actor  User?   @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([tenantId, branchId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([entityType, entityId])
  @@index([correlationId])
}

// ——— FOOD_DINING ———

model DiningMenuCategory {
  id        String   @id @default(cuid())
  tenantId  String
  branchId  String?
  name      String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch? @relation(fields: [branchId], references: [id], onDelete: Cascade)
  items  DiningMenuItem[]

  @@index([tenantId, branchId])
}

model DiningMenuItem {
  id           String   @id @default(cuid())
  tenantId     String
  branchId     String?
  categoryId   String
  name         String
  description  String?  @db.Text
  priceCents   Int
  currency     String   @default("USD")
  imageUrl     String?
  displayOrder Int      @default(0)
  isAvailable  Boolean  @default(true)
  /// Modifier groups / add-ons schema (e.g. [{ id, name, min, max, options: [...] }])
  modifierSchema Json?
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  tenant   Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch   Branch?            @relation(fields: [branchId], references: [id], onDelete: Cascade)
  category DiningMenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  orderLines DiningOrderItem[]

  @@index([tenantId, categoryId])
}

model DiningTable {
  id        String            @id @default(cuid())
  tenantId  String
  branchId  String
  code      String
  label     String?
  capacity  Int?
  status    DiningTableStatus @default(AVAILABLE)
  isActive  Boolean           @default(true)
  metadata  Json?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  deletedAt DateTime?

  tenant        Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch        Branch                @relation(fields: [branchId], references: [id], onDelete: Cascade)
  qrCodes       QrCode[]
  sessions      ConversationSession[]
  waiterCalls   WaiterCallRequest[]
  billRequests  BillRequest[]
  diningOrders  DiningOrder[]

  @@unique([tenantId, branchId, code])
  @@index([tenantId, branchId])
}

model WaiterCallRequest {
  id        String           @id @default(cuid())
  tenantId  String
  branchId  String
  tableId   String?
  sessionId String?
  staffId   String?
  status    WaiterCallStatus @default(PENDING)
  notes     String?          @db.Text
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  tenant  Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch  Branch              @relation(fields: [branchId], references: [id], onDelete: Cascade)
  table   DiningTable?        @relation(fields: [tableId], references: [id], onDelete: SetNull)
  session ConversationSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  staff   Staff?              @relation(fields: [staffId], references: [id], onDelete: SetNull)

  @@index([tenantId, branchId, status])
  @@index([staffId])
}

model BillRequest {
  id        String            @id @default(cuid())
  tenantId  String
  branchId  String
  tableId   String?
  sessionId String?
  status    BillRequestStatus @default(PENDING)
  notes     String?           @db.Text
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  tenant  Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch  Branch              @relation(fields: [branchId], references: [id], onDelete: Cascade)
  table   DiningTable?        @relation(fields: [tableId], references: [id], onDelete: SetNull)
  session ConversationSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([tenantId, branchId, status])
}

model DiningCustomerServiceRequest {
  id        String                @id @default(cuid())
  tenantId  String
  branchId  String
  sessionId String?
  status    DiningSupportStatus   @default(OPEN)
  subject   String?
  details   String?               @db.Text
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  tenant  Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch  Branch              @relation(fields: [branchId], references: [id], onDelete: Cascade)
  session ConversationSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([tenantId, branchId, status])
}

model DiningOrder {
  id                 String            @id @default(cuid())
  tenantId           String
  branchId           String
  diningTableId      String?
  /// Waiter linked to this table/order (optional).
  staffId            String?
  sessionId          String?
  customerPhone      String?
  orderNumber        String
  status             DiningOrderStatus @default(PENDING)
  subtotalCents      Int               @default(0)
  taxCents           Int               @default(0)
  totalCents         Int               @default(0)
  currency           String            @default("USD")
  notes              String?           @db.Text
  paymentMethod      String?
  paidAt             DateTime?
  /// Successful ClickPesa COLLECTION (USSD) that closed this order, if any.
  collectionPaymentId String?               @unique
  collectionPayment   PaymentTransaction?   @relation("CollectionPaymentDiningOrder", fields: [collectionPaymentId], references: [id], onDelete: SetNull)
  claimedAt          DateTime?
  claimedByStaffId   String?
  /// SHA-256 of opaque customer portal secret; raw token shown once when minted.
  portalTokenHash      String?   @unique
  portalTokenCreatedAt DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  deletedAt          DateTime?

  tenant         Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch         Branch               @relation(fields: [branchId], references: [id], onDelete: Cascade)
  diningTable    DiningTable?         @relation(fields: [diningTableId], references: [id], onDelete: SetNull)
  session        ConversationSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  staff          Staff?               @relation("DiningOrderWaiter", fields: [staffId], references: [id], onDelete: SetNull)
  claimedByStaff Staff?               @relation("DiningOrderClaimedBy", fields: [claimedByStaffId], references: [id], onDelete: SetNull)
  items          DiningOrderItem[]
  tips           Tip[]

  @@unique([branchId, orderNumber])
  @@index([tenantId, branchId, status])
  @@index([tenantId, branchId, createdAt])
  @@index([sessionId])
}

model DiningOrderItem {
  id              String                 @id @default(cuid())
  orderId         String
  menuItemId      String
  quantity        Int                    @default(1)
  unitPriceCents  Int
  totalPriceCents Int
  status          DiningOrderItemStatus  @default(PENDING)
  notes           String?                @db.Text
  modifiers       Json?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  order    DiningOrder    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem DiningMenuItem @relation(fields: [menuItemId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([menuItemId])
}

// ——— BEAUTY_GROOMING ———

model BeautyServiceCategory {
  id        String   @id @default(cuid())
  tenantId  String
  branchId  String?
  name      String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  tenant   Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch   Branch?         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  services              BeautyService[]
  providerSpecializations ProviderSpecialization[]

  @@index([tenantId, branchId])
}

model BeautyService {
  id           String   @id @default(cuid())
  tenantId     String
  branchId     String?
  categoryId   String
  name         String
  description  String?  @db.Text
  durationMin  Int?
  priceCents   Int?
  currency     String?  @default("USD")
  imageUrl     String?
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  metadata     Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  tenant   Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch   Branch?               @relation(fields: [branchId], references: [id], onDelete: Cascade)
  category               BeautyServiceCategory    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  providerSpecializations ProviderSpecialization[]
  bookingLines           BeautyBookingService[]

  @@index([tenantId, categoryId])
}

model BeautyStation {
  id        String              @id @default(cuid())
  tenantId  String
  branchId  String
  code      String
  label     String?
  status    BeautyStationStatus @default(AVAILABLE)
  notes     String?             @db.Text
  isActive  Boolean             @default(true)
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  tenant        Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch        Branch                @relation(fields: [branchId], references: [id], onDelete: Cascade)
  qrCodes       QrCode[]
  sessions      ConversationSession[]
  assistance    AssistanceRequest[]
  beautyBookings BeautyBooking[]

  @@unique([tenantId, branchId, code])
  @@index([tenantId, branchId])
}

model ProviderSpecialization {
  id                      String   @id @default(cuid())
  staffId                 String
  title                   String
  description             String?  @db.Text
  beautyServiceCategoryId String?
  beautyServiceId         String?
  createdAt               DateTime @default(now())

  staff                 Staff                  @relation(fields: [staffId], references: [id], onDelete: Cascade)
  beautyServiceCategory BeautyServiceCategory? @relation(fields: [beautyServiceCategoryId], references: [id], onDelete: SetNull)
  beautyService         BeautyService?         @relation(fields: [beautyServiceId], references: [id], onDelete: SetNull)

  @@index([staffId])
  @@index([beautyServiceCategoryId])
  @@index([beautyServiceId])
}

model AssistanceRequest {
  id        String                  @id @default(cuid())
  tenantId  String
  branchId  String
  stationId String?
  sessionId String?
  staffId   String?
  status    AssistanceRequestStatus @default(PENDING)
  notes     String?                 @db.Text
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt

  tenant  Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch  Branch              @relation(fields: [branchId], references: [id], onDelete: Cascade)
  station BeautyStation?      @relation(fields: [stationId], references: [id], onDelete: SetNull)
  session ConversationSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  staff   Staff?              @relation(fields: [staffId], references: [id], onDelete: SetNull)

  @@index([tenantId, branchId, status])
  @@index([staffId])
}

model BeautyBooking {
  id            String              @id @default(cuid())
  tenantId      String
  branchId      String
  stationId     String?
  staffId       String?
  sessionId     String?
  customerPhone String?
  customerName  String?
  bookingNumber String
  status        BeautyBookingStatus @default(BOOKED)
  scheduledAt   DateTime?
  checkedInAt   DateTime?
  paidAt        DateTime?
  totalCents    Int                 @default(0)
  currency      String              @default("USD")
  notes         String?             @db.Text
  isWalkIn      Boolean             @default(false)
  /// SHA-256 of opaque customer portal secret; raw token shown once when minted.
  portalTokenHash      String?   @unique
  portalTokenCreatedAt DateTime?
  /// Successful ClickPesa COLLECTION (USSD) that marked this booking PAID, if any.
  collectionPaymentId String?               @unique
  collectionPayment   PaymentTransaction?   @relation("CollectionPaymentBeautyBooking", fields: [collectionPaymentId], references: [id], onDelete: SetNull)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  deletedAt     DateTime?

  tenant    Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch    Branch               @relation(fields: [branchId], references: [id], onDelete: Cascade)
  station   BeautyStation?       @relation(fields: [stationId], references: [id], onDelete: SetNull)
  staff     Staff?               @relation("BeautyBookingProvider", fields: [staffId], references: [id], onDelete: SetNull)
  session   ConversationSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  services  BeautyBookingService[]
  tips      Tip[]

  @@unique([branchId, bookingNumber])
  @@index([tenantId, branchId, status])
  @@index([tenantId, branchId, scheduledAt])
  @@index([sessionId])
}

model BeautyBookingService {
  id              String                     @id @default(cuid())
  bookingId       String
  beautyServiceId String
  staffId         String?
  durationMin     Int?
  priceCents      Int
  status          BeautyBookingServiceStatus @default(PENDING)
  startedAt       DateTime?
  completedAt     DateTime?
  notes           String?                    @db.Text
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt

  booking       BeautyBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  beautyService BeautyService @relation(fields: [beautyServiceId], references: [id], onDelete: Restrict)
  staff         Staff?        @relation("BeautyBookingServiceStaff", fields: [staffId], references: [id], onDelete: SetNull)

  @@index([bookingId])
  @@index([beautyServiceId])
  @@index([staffId])
}

/// Kitchen Display — public access via opaque token (hash stored).
model KdsToken {
  id               String    @id @default(cuid())
  tenantId         String
  branchId         String
  tokenHash        String    @unique
  name             String
  isActive         Boolean   @default(true)
  expiresAt        DateTime?
  revokedAt        DateTime?
  createdByStaffId String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch    Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdBy Staff? @relation("KdsTokenCreatedBy", fields: [createdByStaffId], references: [id], onDelete: SetNull)

  @@index([tenantId, branchId])
}

/// Queue Display (salon) — public access via opaque token (hash stored).
model QdsToken {
  id               String    @id @default(cuid())
  tenantId         String
  branchId         String
  tokenHash        String    @unique
  name             String
  isActive         Boolean   @default(true)
  expiresAt        DateTime?
  revokedAt        DateTime?
  createdByStaffId String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch    Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdBy Staff? @relation("QdsTokenCreatedBy", fields: [createdByStaffId], references: [id], onDelete: SetNull)

  @@index([tenantId, branchId])
}
