NODE_ENV=development
PORT=3000
# Comma-separated browser origins (Next.js default http://localhost:3001)
# CORS_ORIGINS=http://localhost:3001,http://127.0.0.1:3001
LOG_LEVEL=debug
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tiptap
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
JWT_ACCESS_SECRET=dev_access_secret_change_in_prod_1
JWT_REFRESH_SECRET=dev_refresh_secret_change_in_prod_1
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# Never set true in production. Use only for local/dev or a controlled one-time provision; prefer seeds for admins.
ALLOW_BOOTSTRAP_SUPER_ADMIN=false
SESSION_DEFAULT_TTL_HOURS=24
SWAGGER_ENABLED=true
SWAGGER_PATH=docs

# Phase 5 — encrypt ClickPesa credentials at rest (required to save payment settings; use a long random string in production)
# Example for local dev: PAYMENTS_CREDENTIALS_SECRET=dev_payments_secret_min_32_chars_change_me
PAYMENTS_CREDENTIALS_SECRET=dev_payments_secret_min_32_chars_change_me
# Phase 6 — dashboard / reconciliation heuristics (hours)
# PAYMENTS_STALE_PENDING_HOURS=48
# PAYMENTS_WEBHOOK_STALE_HOURS=72
# CLICKPESA_API_BASE_URL=https://api.clickpesa.com/third-parties
INTERNAL_SERVICES_KEY=tiptap_internal_dev_key

# Bot gateway — Admin → System → “Send test message” calls the gateway with this key (server-side only).
# Must match apps/bot-gateway/.env BOT_GATEWAY_ADMIN_KEY exactly.
# If your gateway runs on another host/port (see apps/bot-gateway/.env PORT, default in code is 3001 but example often uses 3002), set the base URL explicitly.
BOT_GATEWAY_BASE_URL=http://localhost:3002
BOT_GATEWAY_ADMIN_KEY=TIPTAP_multiple_food_and_saloon

# Optional seed overrides
# SEED_ADMIN_EMAIL=admin@tiptap.local
# SEED_ADMIN_PASSWORD=ChangeMe!123
# If you already registered this email, seed skips creating the user — set to true once to force password + ensure SUPER_ADMIN:
# SEED_RESET_ADMIN_PASSWORD=true
