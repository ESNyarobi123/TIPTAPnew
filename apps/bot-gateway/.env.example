PORT=3002

# Enable WhatsApp channel (requires installing @whiskeysockets/baileys)
WHATSAPP_ENABLED=true
WHATSAPP_AUTH_DIR=.wa-auth
WHATSAPP_DEFAULT_LANGUAGE=sw
# Redis-backed session TTL for sender -> sessionToken mapping
WHATSAPP_SESSION_TTL_MS=86400000
WHATSAPP_REDIS_PREFIX=tiptap:whatsapp

# TIPTAP API (public conversation endpoints)
API_BASE_URL=http://localhost:3000/api/v1

# Bot gateway admin (for SUPER_ADMIN test-message tools)
BOT_GATEWAY_ADMIN_KEY=TIPTAP_multiple_food_and_saloon
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
