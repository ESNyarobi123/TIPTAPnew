# TIPTAP Nest API (include /api/v1). Used by the browser and by Next.js server when API_INTERNAL_BASE_URL is unset.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api/v1
# Optional: only for Docker/K8s — server-side fetches (e.g. public /t/[slug] page). Omit when API runs on same host as `next dev`.
# API_INTERNAL_BASE_URL=http://api:3000/api/v1
