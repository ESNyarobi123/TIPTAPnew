{
  "name": "tiptap",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint --continue",
    "test": "turbo run test",
    "test:e2e": "pnpm --filter @tiptap/api test:e2e",
    "format": "prettier --write \"**/*.{ts,js,json,md}\"",
    "db:generate": "pnpm --filter @tiptap/api prisma:generate",
    "db:migrate": "pnpm --filter @tiptap/api prisma:migrate",
    "db:seed": "pnpm --filter @tiptap/api exec prisma db seed"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
