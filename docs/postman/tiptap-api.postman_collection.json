{
  "info": {
    "name": "TIPTAP API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "v1 REST API. Health routes are unversioned; app routes use /api/v1."
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          }
        },
        {
          "name": "GET /ready",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/ready"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /api/v1/auth/login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-correlation-id", "value": "postman-{{$guid}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"SecurePass1ab\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/login"
          }
        }
      ]
    }
  ]
}
